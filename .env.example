NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

DISCORD_TOKEN=
DISCORD_CLIENT_ID=
MOD_LOG_CHANNEL_ID=

GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
GROQ_TIMEOUT_MS=10000
GROQ_TEMPERATURE=0
GROQ_MAX_OUTPUT_TOKENS=180

MYSQLHOST=127.0.0.1
MYSQLPORT=3306
MYSQLUSER=root
MYSQLPASSWORD=
MYSQLDATABASE=discord_bot
MYSQL_CONNECTION_LIMIT=5

AUTO_DELETE_LINKS=true
ALLOW_INVITE_LINKS=false
ALLOW_ATTACHMENT_ONLY_MESSAGES=true
AI_MODERATION_ENABLED=true
AI_MODERATION_MIN_LENGTH=3
MAX_STORED_MESSAGE_CHARS=1000
MODERATE_MESSAGE_EDITS=true
AUTO_RESPONDER_ENABLED=true
AUTO_RESPONDER_COOLDOWN_SECONDS=30
AUTO_RESPONDER_REPLY_KEY=UnknownHub

ALLOWED_LINK_HOSTS=
EXEMPT_CHANNEL_IDS=
EXEMPT_ROLE_IDS=
EXEMPT_USER_IDS=
